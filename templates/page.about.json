    "values": {
      "type": "multicolumn",
      "blocks": {
        "transparency": {
          "type": "column",
          "settings": {
            "title": "Transparency",
            "text": "<p>Every product comes with full ingredient lists, cannabinoid breakdowns, and third-party lab results. We believe you should know exactly what you're getting — no fine print, no surprises.<\/p>",
            "link_label": "",
            "link": ""
          }
        },
        "quality": {
          "type": "column",
          "settings": {
            "title": "Quality First",
            "text": "<p>We never cut corners. From ingredient sourcing to final testing, we prioritize purity, potency, and consistency. Every batch is independently tested by ISO-certified labs.<\/p>",
            "link_label": "",
            "link": ""
          }
        },
        "community": {
          "type": "column",
          "settings": {
            "title": "Community",
            "text": "<p>We're proud to be part of China Grove and the wider North Carolina community. Building a local business and connecting people with quality hemp products is at the heart of what we do.<\/p>",
            "link_label": "",
            "link": ""
          }
        }
      },
